node_modules/
.npm/
.pnp/
.pnp.js

# Next.js build output
.next/
out/
dist/
build/

# Next.js cache
.next/cache/
.next/static/chunks/

# Turbopack / SWC Cache
.swc/
.turbo/

# ─────────────────────────────────────────────────────────────
# ENV DOSYALARI (Kesinlikle Git'e koyma!)
# ─────────────────────────────────────────────────────────────

.env
.env.*
!.env.example
*.local

# ─────────────────────────────────────────────────────────────
# LOG DOSYALARI
# ─────────────────────────────────────────────────────────────

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
debug.log
logs/
*.log

# ─────────────────────────────────────────────────────────────
# LOCK DOSYALARI (paket yöneticin hariç tutulabilir)
