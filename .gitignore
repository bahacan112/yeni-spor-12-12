# ─────────────────────────────────────────────────────────────

.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# VSCode settings (permission-based)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─────────────────────────────────────────────────────────────
# TEST / COVERAGE
# ─────────────────────────────────────────────────────────────

coverage/
*.lcov
jest-html-reporters-*.html
jest-stare/
.nyc_output/

# ─────────────────────────────────────────────────────────────
# TYPESCRIPT OUTPUT
# ─────────────────────────────────────────────────────────────

*.tsbuildinfo
tsconfig.tsbuildinfo

